# ── Required ───────────────────────────────────────────────────────────
API_ID=29308061
API_HASH=your_api_hash_here
BOT_TOKEN=your_bot_token_here
STRING_SESSION=your_pyrogram_string_session_here
OWNER_ID=your_telegram_user_id
LOGGER_ID=your_log_group_id
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net

# ── ShruthiBots API ────────────────────────────────────────────────────
YOUTUBE_API_URL=https://api.shrutibots.site
SHRUTI_API_KEY=your_shruti_api_key_here

# ── Optional (defaults shown) ──────────────────────────────────────────
DURATION_LIMIT_MIN=60     # Max song duration in minutes
QUEUE_LIMIT=5             # Max songs in queue per group (max 5 per group)
SUPPORT_CHAT=https://t.me/yoursupport
